NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# Option A — local (run `docker compose up -d` from repo root)
MONGODB_URI=mongodb://127.0.0.1:27017/ai_interview_resume
# Option B — MongoDB Atlas (use YOUR cluster host, not "cluster.mongodb.net")
# MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/ai_interview_resume?retryWrites=true&w=majority

JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

OPENAI_API_KEY=sk-...

# Optional — leave empty to use local storage (backend/uploads) in development
# Get keys from https://cloudinary.com/console → Dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Base URL for locally stored files (default http://localhost:5000)
API_PUBLIC_URL=http://localhost:5000

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_MONTHLY=price_...
STRIPE_PRICE_ID_YEARLY=price_...

# Optional: for password reset emails (stub logs to console if unset)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@yourapp.com
